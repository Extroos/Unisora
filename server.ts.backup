// Update Server Settings
app.put('/api/servers/:id', (req, res) => {
  const { id } = req.params;
  const updates = req.body;
  const db = loadDB();

  db.servers = db.servers.map(s => {
    if (s.id === id) {
      const settings = s.settings || { notifications: 'all' };
      return {
        ...s,
        ...updates,
        settings: updates.settings ? { ...settings, ...updates.settings } : settings
      };
    }
    return s;
  });

  saveDB(db);
  res.json({ success: true });
});

// Delete Server
app.delete('/api/servers/:id', (req, res) => {
  const { id } = req.params;
  const db = loadDB();

  db.servers = db.servers.filter(s => s.id !== id);
  db.channels = db.channels.filter(c => c.serverId !== id);
  db.categories = db.categories.filter(c => c.serverId !== id);

  saveDB(db);
  res.json({ success: true });
});

// Update Server Member Roles
app.put('/api/servers/:id/members/:userId/roles', (req, res) => {
  const { id, userId } = req.params;
  const { roleIds } = req.body;
  const db = loadDB();

  db.servers = db.servers.map(s => {
    if (s.id === id) {
      const memberRoles = s.memberRoles || {};
      return {
        ...s,
        memberRoles: {
          ...memberRoles,
          [userId]: roleIds
        }
      };
    }
    return s;
  });

  saveDB(db);
  res.json({ success: true });
});

// Server Roles CRUD
app.post('/api/servers/:id/roles', (req, res) => {
  const { id } = req.params;
  const { role } = req.body;
  const db = loadDB();

  db.servers = db.servers.map(s => {
    if (s.id === id) {
      return {
        ...s,
        roles: [...(s.roles || []), role]
      };
    }
    return s;
  });

  saveDB(db);
  res.json({ success: true });
});

app.put('/api/servers/:id/roles/:roleId', (req, res) => {
  const { id, roleId } = req.params;
  const { role } = req.body;
  const db = loadDB();

  db.servers = db.servers.map(s => {
    if (s.id === id) {
      return {
        ...s,
        roles: (s.roles || []).map(r => r.id === roleId ? { ...r, ...role } : r)
      };
    }
    return s;
  });

  saveDB(db);
  res.json({ success: true });
});

app.delete('/api/servers/:id/roles/:roleId', (req, res) => {
  const { id, roleId } = req.params;
  const db = loadDB();

  db.servers = db.servers.map(s => {
    if (s.id === id) {
      return {
        ...s,
        roles: (s.roles || []).filter(r => r.id !== roleId)
      };
    }
    return s;
  });

  saveDB(db);
  res.json({ success: true });
});

// Channel endpoints
app.post('/api/channels', (req, res) => {
  const { serverId, categoryId, name, type, isStage } = req.body;
  const db = loadDB();

  const newId = `ch_${Date.now()}`;
  const newChannel: Channel = {
    id: newId,
    serverId,
    categoryId,
    name,
    type: (isStage ? 'voice' : type) as ChannelType,
    isStage: isStage || false
  };

  db.channels.push(newChannel);
  saveDB(db);
  res.json(newChannel);
});

app.put('/api/channels/:id', (req, res) => {
