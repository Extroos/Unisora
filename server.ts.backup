  db.channels = db.channels.map(c => c.id === id ? { ...c, ...updates } : c);
  saveDB(db);
  res.json({ success: true });
});

app.delete('/api/channels/:id', (req, res) => {
  const { id } = req.params;
  const db = loadDB();

  db.channels = db.channels.filter(c => c.id !== id);
  saveDB(db);
  res.json({ success: true });
});

