  res.json({ success: true });
});

// Messages endpoints
app.post('/api/messages', (req, res) => {
  const { content, channelId, attachments, replyToId, poll } = req.body;
  const db = loadDB();

  const newMessage: Message = {
    id: Math.random().toString(36).substr(2, 9),
    channelId,
    userId: db.currentUser.id,
    content,
    timestamp: new Date().toISOString(),
    attachments,
    replyToId,
    poll,
    reactions: []
  };

  db.messages.push(newMessage);
  saveDB(db);

  res.json(newMessage);
});

app.put('/api/messages/:id', (req, res) => {
  const { id } = req.params;
  const { content } = req.body;
  const db = loadDB();

  db.messages = db.messages.map(m =>
    m.id === id ? { ...m, content, editedAt: new Date().toISOString() } : m
  );
  saveDB(db);
  res.json({ success: true });
});

app.delete('/api/messages/:id', (req, res) => {
  const { id } = req.params;
  const db = loadDB();

  db.messages = db.messages.filter(m => m.id !== id);
  saveDB(db);
  res.json({ success: true });
});

// Message reaction toggling
app.post('/api/messages/:id/reactions', (req, res) => {
  const { id } = req.params;
  const { emoji } = req.body;
  const db = loadDB();

  db.messages = db.messages.map(m => {
    if (m.id !== id) return m;
    const reactions = m.reactions ? [...m.reactions] : [];
    const existing = reactions.find(r => r.emoji === emoji);
    if (existing) {
      if (existing.userIds.includes(db.currentUser.id)) {
        existing.userIds = existing.userIds.filter(uid => uid !== db.currentUser.id);
        existing.count--;
        if (existing.count <= 0) return { ...m, reactions: reactions.filter(r => r.emoji !== emoji) };
        return { ...m, reactions };
      } else {
        existing.userIds.push(db.currentUser.id);
        existing.count++;
        return { ...m, reactions };
      }
    } else {
      reactions.push({ emoji, count: 1, userIds: [db.currentUser.id] });
      return { ...m, reactions };
    }
  });

  saveDB(db);
  res.json({ success: true });
});

// Message pin
app.post('/api/messages/:id/pin', (req, res) => {
  const { id } = req.params;
  const db = loadDB();

  db.messages = db.messages.map(m =>
    m.id === id ? { ...m, pinned: !m.pinned } : m
  );
  saveDB(db);
  res.json({ success: true });
});

// Poll voting
app.post('/api/messages/:id/vote', (req, res) => {
  const { id } = req.params;
  const { optionId } = req.body;
  const db = loadDB();

  db.messages = db.messages.map(msg => {
    if (msg.id !== id || !msg.poll) return msg;

    const newOptions = msg.poll.options.map(opt => {
      const isSelected = opt.id === optionId;
      const wasAlreadyVoted = opt.voterIds.includes(db.currentUser.id);

      if (isSelected) {
        if (wasAlreadyVoted) {
          return {
            ...opt,
            voteCount: opt.voteCount - 1,
            voterIds: opt.voterIds.filter(uid => uid !== db.currentUser.id)
          };
        } else {
          return {
            ...opt,
            voteCount: opt.voteCount + 1,
            voterIds: [...opt.voterIds, db.currentUser.id]
          };
        }
      } else if (!msg.poll?.allowMultiple) {
        if (opt.voterIds.includes(db.currentUser.id)) {
          return {
            ...opt,
            voteCount: opt.voteCount - 1,
            voterIds: opt.voterIds.filter(uid => uid !== db.currentUser.id)
          };
        }
      }
      return opt;
    });

    return { ...msg, poll: { ...msg.poll, options: newOptions } };
  });

  saveDB(db);
  res.json({ success: true });
});

// Group DM endpoints
app.post('/api/dm-channels', (req, res) => {
  const { participantIds } = req.body;
  const db = loadDB();

  const allParticipants = Array.from(new Set([db.currentUser.id, ...participantIds]));
  if (allParticipants.length > 10) return res.status(400).json({ error: 'Too many participants' });

  const newDm: DmChannel = {
    id: `dm-${Date.now()}`,
    participants: allParticipants,
    ownerId: db.currentUser.id,
    createdAt: new Date().toISOString()
  };

  db.dmChannels[newDm.id] = newDm;
  saveDB(db);
  res.json(newDm);
});

// Notifications read-all
app.post('/api/notifications/read-all', (req, res) => {
  const db = loadDB();
  db.notifications = db.notifications.map(n => ({ ...n, read: true }));
  saveDB(db);
  res.json({ success: true });
});

// Threads endpoints
app.post('/api/threads', (req, res) => {
  const { channelId, name, isPrivate } = req.body;
  const db = loadDB();

  const newThread: Thread = {
    id: `t_${Date.now()}`,
    channelId,
    name,
    ownerId: db.currentUser.id,
    createdAt: new Date().toISOString(),
    messageCount: 0,
    isArchived: false,
    isPrivate: isPrivate || false
  };

  db.threads.push(newThread);
  saveDB(db);
  res.json(newThread);
});

app.put('/api/threads/:id', (req, res) => {
  const { id } = req.params;
  const updates = req.body;
  const db = loadDB();

  db.threads = db.threads.map(t => t.id === id ? { ...t, ...updates } : t);
  saveDB(db);
  res.json({ success: true });
});

// Kick Member Endpoint
app.post('/api/servers/:id/kick', (req, res) => {
  const { id } = req.params;
  const { userId } = req.body;
  const db = loadDB();

  db.servers = db.servers.map(s => {
    if (s.id === id) {
      return {
        ...s,
        members: s.members.filter(m => m !== userId)
      };
    }
    return s;
  });

  saveDB(db);
  res.json({ success: true });
});

// Ban Member Endpoint
app.post('/api/servers/:id/ban', (req, res) => {
  const { id } = req.params;
  const { userId } = req.body;
  const db = loadDB();

  db.servers = db.servers.map(s => {
    if (s.id === id) {
      return {
        ...s,
        members: s.members.filter(m => m !== userId)
      };
    }
    return s;
  });

  saveDB(db);
  res.json({ success: true });
});

app.listen(port, () => {
  console.log(`BRAND app Express backend listening at http://localhost:${port}`);
});
