import React, { useState } from 'react';
import { motion, AnimatePresence } from 'motion/react';
import { X, FolderPlus } from 'lucide-react';
import { useAppStore } from '../../store/useAppStore';
import { cn } from '../../lib/utils';

interface CreateFolderModalProps {
  isOpen: boolean;
  onClose: () => void;
}

const COLORS = [
  { hex: '#5865f2', name: 'Blurple' },
  { hex: '#ed4245', name: 'Rose' },
  { hex: '#3ba55c', name: 'Emerald' },
  { hex: '#faa61a', name: 'Amber' },
  { hex: '#eb459e', name: 'Pink' },
  { hex: '#7289da', name: 'Indigo' },
  { hex: '#43b581', name: 'Teal' },
  { hex: '#8e44ad', name: 'Purple' },
];

export function CreateFolderModal({ isOpen, onClose }: CreateFolderModalProps) {
  const [name, setName] = useState('');
  const [selectedColor, setSelectedColor] = useState(COLORS[0].hex);
  const addFolder = useAppStore(state => state.addFolder);

  const handleSubmit = (e: React.FormEvent) => {
    e.preventDefault();
    if (!name.trim()) return;
    addFolder(name.trim(), selectedColor);
    setName('');
    onClose();
  };

  return (
    <AnimatePresence>
      {isOpen && (
        <div className="fixed inset-0 z-100 flex items-center justify-center p-4">
          <motion.div
            initial={{ opacity: 0 }}
            animate={{ opacity: 1 }}
            exit={{ opacity: 0 }}
            onClick={onClose}
            className="absolute inset-0 bg-black/80 backdrop-blur-md"
          />
          <motion.div
            initial={{ opacity: 0, scale: 0.95, y: 20 }}
            animate={{ opacity: 1, scale: 1, y: 0 }}
            exit={{ opacity: 0, scale: 0.95, y: 20 }}
            className="relative w-full max-w-md glass-heavy rounded-[24px] shadow-2xl border border-white/10 overflow-hidden"
          >
            <div className="p-8 pb-4">
              <div className="flex items-center justify-between mb-8">
                <div className="flex items-center gap-4">
                  <div className="w-12 h-12 rounded-2xl bg-accent/20 flex items-center justify-center text-accent shadow-lg shadow-accent/10">
                    <FolderPlus size={24} />
                  </div>
                  <div>
                    <h2 className="text-2xl font-bold text-white tracking-tight">New Folder</h2>
                    <p className="text-[13px] text-text-muted font-medium">Organize your spaces</p>
                  </div>
                </div>
                <button onClick={onClose} className="p-2 rounded-full hover:bg-white/5 text-text-muted hover:text-white transition-all">
                  <X size={20} />
                </button>
              </div>

              <form onSubmit={handleSubmit} className="space-y-8">
                <div className="space-y-3">
                  <label className="text-[11px] font-bold uppercase tracking-[0.2em] text-text-muted ml-1">Name</label>
                  <input
                    autoFocus
                    type="text"
                    placeholder="e.g. Work, Gaming, Social..."
                    value={name}
                    onChange={(e) => setName(e.target.value)}
                    className="w-full bg-surface-2/50 border border-white/5 rounded-2xl px-5 py-4 text-[16px] text-white placeholder:text-text-muted focus:outline-none focus:border-accent/40 focus:bg-surface-2 transition-all shadow-inner"
                  />
                </div>

                <div className="space-y-4">
                  <label className="text-[11px] font-bold uppercase tracking-[0.2em] text-text-muted ml-1">Folder Color</label>
                  <div className="grid grid-cols-4 gap-4">
                    {COLORS.map(color => (
                      <button
                        key={color.hex}
                        type="button"
                        onClick={() => setSelectedColor(color.hex)}
                        title={color.name}
                        className={cn(
                          "group relative aspect-square rounded-2xl transition-all duration-300 flex items-center justify-center",
                          selectedColor === color.hex ? "ring-2 ring-white ring-offset-4 ring-offset-black/20" : "hover:scale-105"
                        )}
                        style={{ backgroundColor: color.hex }}
                      >
                        {selectedColor === color.hex && (
                          <motion.div 
                            layoutId="check"
                            className="w-2 h-2 rounded-full bg-white shadow-sm"
                          />
                        )}
                      </button>
                    ))}
                  </div>
                </div>

                <div className="flex items-center gap-4 pt-4 pb-4">
                  <button
                    type="button"
                    onClick={onClose}
                    className="flex-1 px-6 py-4 rounded-2xl font-bold text-[15px] text-text-secondary hover:text-white hover:bg-white/5 transition-all"
                  >
                    Cancel
                  </button>
                  <button
                    type="submit"
                    disabled={!name.trim()}
                    className="flex-2 bg-accent hover:bg-accent-hover disabled:opacity-30 disabled:grayscale text-white py-4 rounded-2xl font-bold text-[15px] transition-all shadow-xl shadow-accent/20 active:scale-95 flex items-center justify-center gap-2"
                  >
                    <span>Create Folder</span>
                  </button>
                </div>
              </form>
            </div>
          </motion.div>
        </div>
      )}
    </AnimatePresence>
  );
}
